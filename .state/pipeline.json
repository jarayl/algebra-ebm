  "audit_fixes_applied": {
    "date": "2026-02-15T12:00:00Z",
    "description": "Comprehensive audit identified 4 issues; 2 code fixes applied, 1 diagnosed, 1 no-action",
    "fixes": [
      {
        "id": "AUDIT-001",
        "title": "Fix rule selection in evaluation",
        "status": "APPLIED",
        "file": "src/algebra/algebra_evaluation.py",
        "description": "evaluate_model() now extracts rules_applied per problem and builds rule_weights (1.0 for relevant, 0.0 for irrelevant). Previously all 4 energies were always summed for multi-rule problems."
      },
      {
        "id": "AUDIT-002",
        "title": "Fix inference hyperparameter mismatch",
        "status": "APPLIED",
        "file": "src/algebra/algebra_evaluation.py",
        "description": "Removed hardcoded T=20/step_size=0.1 defaults from evaluate_model(). Now uses InferenceConfig defaults (max_iterations=50, step_size=0.01) which are 10x smaller step and 2.5x more iterations."
      },
      {
        "id": "AUDIT-003",
        "title": "Single-rule accuracy investigation",
        "status": "DIAGNOSED",
        "description": "Training converged for all 4 rules with 9-10 unit energy gaps. Root cause of low accuracy (distribute=2.1%, isolate=7.0%, divide=5.7%) is IRED inference converging to local minima in embedding space. combine works (100%) because output≈input. Requires inference strategy improvements (multi-start, momentum, more landscapes)."
      },
      {
        "id": "AUDIT-004",
        "title": "evaluate_with_composition dead code",
        "status": "NO_ACTION",
        "description": "Function is actually called in comparison eval path. Issue 1 fix covers standard eval paths. No changes needed."
      }
    ],
    "next_steps": [
      "Push code fixes to GitHub so cluster jobs use updated code",
      "Resubmit evaluation suite (exp_001 through exp_005) with AUDIT-001 and AUDIT-002 fixes",
      "If multi-rule accuracy improves but single-rule remains low, investigate IRED inference improvements for AUDIT-003"
    ]
  },
  "dataset_generation_audit": {
    "date": "2026-02-14T18:30:00Z",
    "description": "Deep audit of equation generation found critical math errors, format mismatches, and broken validation. ALL existing models were trained on flawed data and ALL evaluation used incorrect test datasets. Full retraining and re-evaluation required.",
    "fixes": [
      {
        "id": "DATAGEN-001",
        "title": "Fix mathematically incorrect test datasets",
        "status": "APPLIED",
        "files": ["src/algebra/algebra_dataset.py", "scripts/create_test_datasets.py", "results/test_datasets/*.json"],
        "description": "MultiRuleDataset._generate_sequential_problem() produced equations where input != target mathematically (e.g., '-3*x+4*x=6' with target 'x=7' when correct answer is x=6). Rewrote generation to work backwards from known integer solutions. Added check_equation_equivalence() validation. Regenerated all 175 test problems, verified 0 errors via independent SymPy check."
      },
      {
        "id": "DATAGEN-002",
        "title": "Fix train/test format mismatch",
        "status": "APPLIED",
        "files": ["src/algebra/algebra_dataset.py"],
        "description": "Training data for distribute and combine rules generated bare expressions without '=' signs (e.g., '2*(3*x+5)' -> '6*x+10'), while test data had full equations (e.g., '2*x+3=7' -> 'x=2'). Changed all 4 rules to produce equations: distribute now generates 'a*(b*x+c)=d -> a*b*x+a*c=d', combine generates 'a*x+b*x=c -> (a+b)*x=c'. Fixed in both AlgebraDataset and CombinedAlgebraDataset."
      },
      {
        "id": "DATAGEN-003",
        "title": "Fix ConstrainedDataset invalid target equation",
        "status": "APPLIED",
        "files": ["src/algebra/algebra_dataset.py"],
        "description": "range_constraint target included metadata in equation string: 'x = 5 (range: 1-20)' which is not a parseable equation. Changed to 'x = 5'."
      },
      {
        "id": "DATAGEN-004",
        "title": "Fix validation functions returning tuples used as booleans",
        "status": "APPLIED",
        "files": ["src/algebra/algebra_dataset.py"],
        "description": "validate_equation_syntax() returns (bool, str, expr) 3-tuple and check_equation_equivalence() returns (bool, str) 2-tuple, but all 5 call sites did 'if not func(...)' which always evaluates to False for non-empty tuples. ALL validation was silently bypassed - no equations were ever actually validated. Fixed all call sites to unpack tuples: 'is_valid, _, _ = validate_equation_syntax(eq)'. Also fixed solve_equation() tuple unpacking for integer solution checks."
      },
      {
        "id": "DATAGEN-005",
        "title": "Fix evaluation seeding for reproducibility",
        "status": "APPLIED",
        "files": ["eval_algebra.py"],
        "description": "eval_algebra.py set np.random.seed() but AlgebraDataset uses Python's random module. Added random.seed() calls alongside np.random.seed() at all 3 seeding locations for deterministic dataset generation."
      }
    ],
    "impact": {
      "training_data_invalidated": true,
      "test_data_invalidated": true,
      "reason": "DATAGEN-002 changes the format of distribute and combine training data from expressions to equations. All 5 existing trained models (distribute, combine, isolate, divide, monolithic) learned on the old expression format and must be retrained. DATAGEN-004 means no training data was ever validated for correctness. Test datasets were regenerated with correct math.",
      "all_previous_results_invalid": true,
      "results_invalidation_reason": "Test datasets contained mathematically wrong equations. Even if models were correct, evaluation scores are meaningless."
    },
    "required_actions": [
      "1. Push all code changes to GitHub",
      "2. Retrain ALL 5 models (distribute, combine, isolate, divide, monolithic) with fixed training data",
      "3. Re-evaluate ALL experiments (exp_001 through exp_007) with new models and corrected test datasets",
      "4. Cancel any currently running evaluation jobs (they use old models trained on flawed data)"
    ]
  },
